# DecapBridge configuration (https://decapbridge.com)
# Get a free site UUID by signing up at decapbridge.com
DECAP_BRIDGE_SITE_UUID=

# GitHub PAT used by the save-page serverless function to commit JSON files.
# Use a fine-grained PAT scoped to ONLY this repo with Contents: Read+Write.
# Rotate annually. See SETUP.md.
GITHUB_PAT=

# Target repo identifier for the save function. Format: owner/name
# Example: Woollbert/AviaraDesignCo
GITHUB_REPO=

# Branch to commit edits to. Almost always "main".
GITHUB_BRANCH=main

# Public URL of the deployed site. Used for redirects after admin actions.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Shared secret used by /api/save-page to authorize publish requests from the
# Puck editor. Generate a long random string and store it here AND in your
# Vercel/Netlify env. The editor reads this server-side and injects via the
# x-editor-token header — it never appears in client source code.
#
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# Note: this is MVP-level auth. The /admin/pages/[slug] route should ALSO be
# gated behind DecapBridge auth (or similar) so only authenticated editors can
# reach the page that holds this token. See SPEC.md §3 risks.
EDITOR_SHARED_TOKEN=

# --- Contact form (api/contact) ---
# The form sends inquiries directly through Gmail SMTP. Inquiries arrive in
# the configured inbox like any other email — Reply-To is set to the inquirer
# so hitting "Reply" responds to the customer, not the website.
#
# Setup for Gmail (one-time, ~3 min):
#   1. Enable 2-Step Verification on aviaradesignco@gmail.com if not already on
#      (myaccount.google.com → Security → 2-Step Verification).
#   2. Generate an App Password:
#      myaccount.google.com → Security → App passwords → "Mail" → "Other"
#      → name it "Aviara Site". Google shows a 16-character password ONCE —
#      copy it (spaces optional, they're ignored).
#   3. Paste that password into SMTP_PASS below (and in Vercel env vars).
# The app password can be revoked anytime from the same Google page without
# affecting the main account password.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=aviaradesignco@gmail.com
SMTP_PASS=

# Optional. Where inquiries are delivered. Defaults to site.email, then SMTP_USER.
CONTACT_TO_EMAIL=

# --- Analytics + Search Console (optional, recommended) ---
# Both are NEXT_PUBLIC_* so they're exposed to the browser (which is correct —
# the GA measurement ID and the GSC verification token are designed to be
# public-facing strings, not secrets).

# Google Analytics 4 measurement ID. Sign up at analytics.google.com → create a
# GA4 property for aviaradesignco.com → "Data Streams" → click the web stream
# → copy the "Measurement ID" (format: G-XXXXXXXXXX).
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Search Console ownership verification. At search.google.com/search-console
# → "Add property" → "URL prefix" → enter https://www.aviaradesignco.com → pick
# the "HTML tag" verification method. Google shows a meta tag — copy only the
# value inside content="..." here.
NEXT_PUBLIC_GSC_VERIFICATION=
