# DecapBridge configuration (https://decapbridge.com)
# Get a free site UUID by signing up at decapbridge.com
DECAP_BRIDGE_SITE_UUID=

# GitHub PAT used by the save-page serverless function to commit JSON files.
# Use a fine-grained PAT scoped to ONLY this repo with Contents: Read+Write.
# Rotate annually. See SETUP.md.
GITHUB_PAT=

# Target repo identifier for the save function. Format: owner/name
# Example: Woollbert/AviaraDesignCo
GITHUB_REPO=

# Branch to commit edits to. Almost always "main".
GITHUB_BRANCH=main

# Public URL of the deployed site. Used for redirects after admin actions.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Shared secret used by /api/save-page to authorize publish requests from the
# Puck editor. Generate a long random string and store it here AND in your
# Vercel/Netlify env. The editor reads this server-side and injects via the
# x-editor-token header — it never appears in client source code.
#
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# Note: this is MVP-level auth. The /admin/pages/[slug] route should ALSO be
# gated behind DecapBridge auth (or similar) so only authenticated editors can
# reach the page that holds this token. See SPEC.md §3 risks.
EDITOR_SHARED_TOKEN=
